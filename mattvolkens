        playGrungeAnthem(true);
      } else {
        finalCard.className = "final-card lose";
        finalCard.innerHTML = "JOSH WINS.<br />FLAWLESS VICTORY.<br />(please still consider hiring)<br /><br />PRESS R TO TRY AGAIN";
        playGrungeAnthem(false);
      }
    }

    function restartGame() {
      game.started = false;
      game.over = false;
      game.playerScore = 0;
      game.joshScore = 0;
      game.particles.length = 0;
      game.bottleCaps.length = 0;
      game.floorPedals.length = 0;
      game.centaur.active = false;
      game.centaur.drop = null;
      game.centaur.nextEventAt = performance.now() + rand(15000, 45000);
      game.penguins.active = false;
      game.penguins.nextEventAt = performance.now() + rand(9000, 22000);
      game.roundLocked = false;
      game.nextPantherAt = performance.now() + rand(7000, 15000);
      game.dramaFreeze = 0;
      game.josh.flash = 0;
      document.querySelectorAll(".resume-item").forEach((card) => card.classList.remove("visible"));
      resumeStatus.textContent = "RESUME LOCKED. SCORE TO EXTRACT PROFESSIONAL CREDENTIALS.";
      updateScoreboard();
      resetBall(-1);
      appRoot.classList.add("prestart");
      splashScreen.classList.remove("hidden");
      finalScreen.classList.add("hidden");
      resumeFlyover.classList.add("hidden");
      resumeFlyover.classList.remove("active");
    }

    function startGame() {
      ensureAudio();
      appRoot.classList.remove("prestart");
      splashScreen.classList.add("hidden");
      finalScreen.classList.add("hidden");
      game.started = true;
      game.over = false;
      game.playerScore = 0;
      game.joshScore = 0;
      updateScoreboard();
      startMusicLoop();
      resumeFlyover.classList.add("hidden");
      resumeFlyover.classList.remove("active");
      resetBall(Math.random() > 0.5 ? 1 : -1);
    }

    function scheduleCentaur(now) {
      game.centaur.active = true;
      game.centaur.dir = Math.random() > 0.5 ? 1 : -1;
      game.centaur.x = game.centaur.dir === 1 ? -game.centaur.width - 20 : W + 20;
      game.centaur.y = rand(H * 0.18, H * 0.72);
      game.centaur.drop = Math.random() > 0.45 ? {
        kind: ["KILT", "MORNING GLORY", "PANTHER CUB", "AT+", "BONSAI"][Math.floor(Math.random() * 5)],
        x: null,
        y: null,
        rot: rand(-0.4, 0.4)
      } : null;
      game.centaur.hoofClock = 0;
      game.centaur.nextEventAt = now + rand(15000, 45000);
      playCentaurGallop();
    }

    function schedulePenguins(now) {
      const p = game.penguins;
      p.active = true;
      p.dir = Math.random() > 0.5 ? 1 : -1;
      p.count = Math.floor(rand(2, 5));
      p.x = p.dir === 1 ? -p.width * p.count - 60 : W + 60;
      p.y = rand(H * 0.12, H * 0.8);
      p.wobble = 0;
      p.nextEventAt = now + rand(11000, 26000);
      playPenguinMarch();
      showOverlay("PENGUIN INTERRUPTION", "var(--cyan)");
    }

    function update(delta, now) {
      if (!game.started || game.over) return;

      game.dramaFreeze = Math.max(0, game.dramaFreeze - delta);

      if (game.dramaFreeze <= 0) {
        if (game.up) game.player.y -= game.player.speed * delta;
        if (game.down) game.player.y += game.player.speed * delta;

        const mouseTarget = game.mouseY - game.player.height / 2;
        game.player.y += (mouseTarget - game.player.y) * Math.min(1, delta * 8);
        game.player.y = clamp(game.player.y, 10, H - game.player.height - 10);

        game.josh.reactionLag += delta;
        if (game.josh.reactionLag > 0.18) {
          game.josh.reactionLag = 0;
          game.josh.drift = rand(-90, 90);
        }
        const targetJoshY = game.ball.y + game.josh.drift + Math.sin(now * 0.002) * 28;
        game.josh.y += (targetJoshY - game.josh.y) * Math.min(1, delta * 1.65);
        game.josh.y = clamp(game.josh.y, 74, H - 74);
        game.josh.wobble += delta * 8;

        game.ball.x += game.ball.vx * delta;
        game.ball.y += game.ball.vy * delta;
      }

      if (game.ball.y <= 10 || game.ball.y >= H - 10) {
        game.ball.vy *= -1;
        game.ball.y = clamp(game.ball.y, 10, H - 10);
        playBounce();
        playWallTick();
      }

      const playerHit = (
        game.ball.x - game.ball.size / 2 <= game.player.x + game.player.width &&
        game.ball.y >= game.player.y &&
        game.ball.y <= game.player.y + game.player.height &&
        game.ball.vx < 0
      );

      if (playerHit) {
        const impact = (game.ball.y - (game.player.y + game.player.height / 2)) / (game.player.height / 2);
        game.ball.vx = Math.abs(game.ball.vx) + 12;
        game.ball.vy = impact * 240;
        game.ball.x = game.player.x + game.player.width + game.ball.size / 2;
        playBounce();
        spawnParticles(game.ball.x, game.ball.y, "#54f7ff");
      }

      const joshLeft = game.josh.x - game.josh.width / 2;
      const joshTop = game.josh.y - game.josh.height / 2;
      const joshHit = (
        game.ball.x + game.ball.size / 2 >= joshLeft &&
        game.ball.x - game.ball.size / 2 <= joshLeft + game.josh.width &&
        game.ball.y >= joshTop &&
        game.ball.y <= joshTop + game.josh.height &&
        game.ball.vx > 0
      );

      if (joshHit) {
        const impact = (game.ball.y - game.josh.y) / (game.josh.height / 2);
        game.ball.vx = -Math.abs(game.ball.vx) - 4;
        game.ball.vy = impact * 205 + Math.sin(game.josh.wobble * 2) * 16;
        game.ball.x = joshLeft - game.ball.size / 2;
        playBounce();
        spawnParticles(game.ball.x, game.ball.y, "#ff4fae");
      }

      if (!game.roundLocked && game.ball.x < -30) {
        scoreJosh();
      } else if (!game.roundLocked && game.ball.x > W + 30) {
        scorePlayer();
      }

      game.josh.flash = Math.max(0, game.josh.flash - delta);

      game.particles = game.particles.filter((p) => {
        p.x += p.vx * delta;
        p.y += p.vy * delta;
        p.vx *= 0.96;
        p.vy *= 0.96;
        p.life -= delta;
        return p.life > 0;
      });

      game.bottleCaps = game.bottleCaps.filter((cap) => {
        cap.x += cap.vx * delta;
        cap.y += cap.vy * delta;
        cap.vy += 420 * delta;
        cap.rotation += cap.spin * delta;
        cap.life -= delta;
        return cap.life > 0 && cap.y < H + 40;
      });

      if (!game.centaur.active && now >= game.centaur.nextEventAt) {
        scheduleCentaur(now);
      }

      if (!game.penguins.active && now >= game.penguins.nextEventAt) {
        schedulePenguins(now);
      }

      if (now >= game.nextPantherAt) {
        game.nextPantherAt = now + rand(9000, 18000);
        playPantherScream();
      }

      if (game.centaur.active) {
        const c = game.centaur;
        c.x += c.speed * delta * c.dir;
        c.hoofClock += delta;
        if (c.hoofClock > 0.18) {
          c.hoofClock = 0;
          playCentaurGallop();
        }
        if (c.drop && c.drop.x === null && Math.random() > 0.94) {
          c.drop.x = c.x + c.width * 0.45;
          c.drop.y = c.y + c.height * 0.78;
          for (let i = 0; i < 3; i++) {
            game.floorPedals.push({
              kind: ["KILT", "MORNING GLORY", "PANTHER CUB", "AT+", "BONSAI"][Math.floor(Math.random() * 5)],
              x: c.drop.x + rand(-34, 34),
              y: c.drop.y + rand(20, 140),
              rot: rand(-0.45, 0.45),
              size: rand(1.05, 1.45)
            });
          }
          showOverlay("PEDAL DROP", "var(--cyan)");
        }
        if ((c.dir === 1 && c.x > W + c.width + 20) || (c.dir === -1 && c.x < -c.width - 30)) {
          c.active = false;
        }
      }

      if (game.penguins.active) {
        const p = game.penguins;
        p.x += p.speed * delta * p.dir;
        p.wobble += delta * 8;
        if (Math.random() > 0.992) {
          playPenguinMarch();
        }
        if ((p.dir === 1 && p.x > W + p.width * p.count + 30) || (p.dir === -1 && p.x < -p.width * p.count - 90)) {
          p.active = false;
        }
      }
    }

    function drawBackground() {
      ctx.fillStyle = "#03100b";
      ctx.fillRect(0, 0, W, H);

      ctx.strokeStyle = "rgba(116,255,104,0.18)";
      ctx.lineWidth = 4;
      ctx.setLineDash([16, 16]);
      ctx.beginPath();
      ctx.moveTo(CENTER_X, 0);
      ctx.lineTo(CENTER_X, H);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.strokeStyle = "rgba(84,247,255,0.2)";
      ctx.strokeRect(8, 8, W - 16, H - 16);

      for (let i = 0; i < 18; i++) {
        ctx.fillStyle = `rgba(84,247,255,${0.02 + (i % 2) * 0.015})`;
        ctx.fillRect(0, i * 30, W, 2);
      }
    }

    function drawPlayerPaddle() {
      const p = game.player;
      ctx.fillStyle = "#74ff68";
      ctx.fillRect(p.x, p.y, p.width, p.height);
      ctx.fillStyle = "#d5ffd1";
      ctx.fillRect(p.x + 4, p.y + 8, 4, p.height - 16);
      ctx.fillStyle = "rgba(116,255,104,0.22)";
      ctx.fillRect(p.x - 3, p.y - 3, p.width + 6, p.height + 6);
    }

    function drawBall() {
      const b = game.ball;
      const x = b.x - b.size / 2;
      const y = b.y - b.size / 2;
      ctx.save();
      ctx.translate(x, y);
      ctx.fillStyle = "#7f2cff";
      ctx.fillRect(0, 2, b.size, b.size - 4);
      ctx.fillStyle = "#d8c1ff";
      ctx.fillRect(3, 5, b.size - 6, b.size - 10);
      ctx.fillStyle = "#ffca4d";
      ctx.fillRect(6, 8, 8, 6);
      ctx.fillStyle = "#111";
      ctx.fillRect(2, 0, 4, 2);
      ctx.fillRect(b.size - 6, 0, 4, 2);
      ctx.restore();
    }

    function drawJoshHead() {
      const j = game.josh;
      const x = j.x;
      const y = j.y + Math.sin(j.wobble * 2.1) * 5;
      const flash = j.flash > 0 ? 1 : 0;

      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(Math.sin(j.wobble) * 0.035);

      ctx.fillStyle = "rgba(255,90,20,0.18)";
      ctx.beginPath();
      ctx.ellipse(0, 10, 60, 74, 0, 0, Math.PI * 2);
      ctx.fill();

      ctx.save();
      ctx.beginPath();
      ctx.ellipse(0, 6, 54, 66, 0, 0, Math.PI * 2);
      ctx.clip();
      if (joshPhoto.complete && joshPhoto.naturalWidth > 0) {
        const sx = joshPhoto.naturalWidth * 0.18;
        const sy = joshPhoto.naturalHeight * 0.05;
        const sw = joshPhoto.naturalWidth * 0.64;
        const sh = joshPhoto.naturalHeight * 0.66;
        ctx.drawImage(joshPhoto, sx, sy, sw, sh, -58, -58, 116, 128);
      } else {
        ctx.fillStyle = "#ff5a14";
        ctx.fillRect(-60, -70, 120, 150);
      }
      if (flash) {
        ctx.fillStyle = "rgba(255, 63, 80, 0.24)";
        ctx.fillRect(-70, -80, 140, 170);
      }
      ctx.restore();

      ctx.strokeStyle = "#f4efe8";
      ctx.lineWidth = 4;
      ctx.beginPath();
      ctx.ellipse(0, 6, 54, 66, 0, 0, Math.PI * 2);
      ctx.stroke();

      ctx.fillStyle = "rgba(0,0,0,0.5)";
      ctx.fillRect(-38, 54, 76, 18);
      ctx.fillStyle = "#ffca4d";
      ctx.font = '11px "Press Start 2P", monospace';
      ctx.fillText("JOSH", -28, 67);

      ctx.restore();
    }

    function drawPenguins() {
      const p = game.penguins;
      if (!p.active) return;

      for (let i = 0; i < p.count; i++) {
        const offsetX = i * (p.width * 0.68) * (p.dir === 1 ? -1 : 1);
        const bob = Math.sin(p.wobble + i * 0.9) * 8;
        ctx.save();
        ctx.translate(p.x + offsetX, p.y + bob);
        if (p.dir === -1) {
          ctx.scale(-1, 1);
        }

        ctx.fillStyle = "rgba(84,247,255,0.12)";
        ctx.beginPath();
        ctx.ellipse(0, 28, 28, 36, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = "#0a1016";
        ctx.beginPath();
        ctx.ellipse(0, 18, 22, 34, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = "#f5fbff";
        ctx.beginPath();
        ctx.ellipse(0, 24, 12, 24, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = "#ff9a39";
        ctx.beginPath();
        ctx.moveTo(8, 14);
        ctx.lineTo(24, 18);
        ctx.lineTo(8, 24);
        ctx.closePath();
        ctx.fill();
        ctx.fillRect(-10, 52, 8, 4);
        ctx.fillRect(4, 52, 8, 4);

        ctx.fillStyle = "#fff";
        ctx.fillRect(-8, 8, 4, 4);
        ctx.fillRect(4, 8, 4, 4);
        ctx.fillStyle = "#111";
        ctx.fillRect(-7, 9, 2, 2);
        ctx.fillRect(5, 9, 2, 2);
        ctx.restore();
      }
    }

    function drawCentaur() {
      const c = game.centaur;
      if (!c.active) {
        if (c.drop && c.drop.x !== null) {
          drawDroppedItem(c.drop);
        }
        return;
      }

      ctx.save();
      ctx.translate(c.x, c.y);
      if (c.dir === -1) {
        ctx.scale(-1, 1);
        ctx.translate(-c.width, 0);
      }

      const bounce = Math.sin(performance.now() * 0.02) * 4;
      ctx.translate(0, bounce);

      ctx.fillStyle = "#b57b4e";
      ctx.fillRect(18, 42, 92, 32);
      ctx.fillRect(34, 24, 26, 26);
      ctx.fillRect(60, 16, 34, 28);

      ctx.fillStyle = "#f0c79c";
      ctx.fillRect(62, -2, 26, 24);
      ctx.fillRect(69, -12, 10, 12);
      ctx.fillStyle = "#2a1a12";
      ctx.fillRect(65, -14, 20, 6);
      ctx.fillRect(72, -22, 6, 8);

      ctx.fillStyle = "#392117";
      [24, 48, 80, 100].forEach((legX, i) => {
        const kick = Math.sin(performance.now() * 0.024 + i) * 6;
        ctx.fillRect(legX, 68, 8, 26 + kick);
      });

      ctx.fillStyle = "#ff4fae";
      ctx.fillRect(50, 24, 14, 20);
      ctx.fillStyle = "#54f7ff";
      ctx.fillRect(46, 30, 8, 8);

      ctx.fillStyle = "#2c120d";
      ctx.fillRect(8, 42, 16, 8);
      ctx.fillRect(110, 44, 14, 8);

      ctx.restore();

      if (c.drop && c.drop.x !== null) {
        drawDroppedItem(c.drop);
      }
    }

    function drawDroppedItem(drop) {
      ctx.save();
      ctx.translate(drop.x, drop.y);
      ctx.rotate(drop.rot);
      ctx.scale(drop.size || 1, drop.size || 1);
      ctx.fillStyle = ["KILT", "AT+"].includes(drop.kind) ? "#ff5a14" : "#7f2cff";
      ctx.fillRect(-12, -10, 24, 20);
      ctx.fillStyle = "#f6e6ff";
      ctx.fillRect(-8, -5, 16, 8);
      ctx.fillStyle = "#ffca4d";
      ctx.fillRect(-3, -14, 6, 4);
      ctx.fillStyle = "#101010";
      ctx.font = '6px "Press Start 2P", monospace';
      const label = drop.kind === "MORNING GLORY" ? "MG" : drop.kind === "PANTHER CUB" ? "PC" : drop.kind;
      ctx.fillText(label.slice(0, 4), -9, 3);
      ctx.restore();
    }

    function drawParticles() {
      game.particles.forEach((p) => {
        ctx.globalAlpha = Math.max(0, p.life * 1.6);
        ctx.fillStyle = p.color;
        ctx.fillRect(p.x, p.y, p.size, p.size);
      });
      ctx.globalAlpha = 1;
    }

    function drawBottleCaps() {
      game.bottleCaps.forEach((cap) => {
        ctx.save();
        ctx.globalAlpha = Math.max(0.25, Math.min(1, cap.life / 2));
        ctx.translate(cap.x, cap.y);
        ctx.rotate(cap.rotation);
        ctx.fillStyle = cap.fill;
        ctx.beginPath();
        ctx.arc(0, 0, cap.size, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = cap.stripe;
        ctx.lineWidth = 3;
        for (let i = 0; i < 8; i++) {
          ctx.save();
          ctx.rotate((Math.PI * 2 * i) / 8);
          ctx.beginPath();
          ctx.moveTo(cap.size - 4, 0);
          ctx.lineTo(cap.size + 2, 0);
          ctx.stroke();
          ctx.restore();
        }
        ctx.fillStyle = "rgba(255,255,255,0.25)";
        ctx.beginPath();
        ctx.arc(-cap.size * 0.2, -cap.size * 0.2, cap.size * 0.35, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      });
      ctx.globalAlpha = 1;
    }

    function drawFloorPedals() {
      game.floorPedals.forEach((pedal) => drawDroppedItem(pedal));
    }

    function draw() {
      drawBackground();
      drawPlayerPaddle();
      drawJoshHead();
      drawBall();
      drawCentaur();
      drawPenguins();
      drawFloorPedals();
      drawParticles();
      drawBottleCaps();

      ctx.fillStyle = "rgba(116,255,104,0.16)";
      ctx.font = '14px "Press Start 2P", monospace';
      ctx.fillText("YOU", 20, 24);
      ctx.fillText("JOSH", W - 100, 24);
    }

    function loop(now) {
      const delta = Math.min(0.033, (now - game.lastTime) / 1000);
      game.lastTime = now;
      update(delta, now);
      draw();
      requestAnimationFrame(loop);
    }

    window.addEventListener("mousemove", (event) => {
      const rect = canvas.getBoundingClientRect();
      const scaleY = H / rect.height;
      game.mouseY = (event.clientY - rect.top) * scaleY;
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "ArrowUp") game.up = true;
      if (event.key === "ArrowDown") game.down = true;

      if ((event.code === "Space" || event.key === "Enter") && !game.started) {
        startGame();
      }

      if ((event.key === "r" || event.key === "R") && game.over) {
        restartGame();
      }
    });

    window.addEventListener("keyup", (event) => {
      if (event.key === "ArrowUp") game.up = false;
      if (event.key === "ArrowDown") game.down = false;
    });

    splashScreen.addEventListener("click", () => {
      if (!game.started) startGame();
    });

    window.addEventListener("resize", () => {
      // The canvas uses a fixed internal resolution for pixel art; CSS handles scaling.
    });

    updateScoreboard();
    resetBall(-1);
    requestAnimationFrame(loop);
  </script>
</body>
</html>
