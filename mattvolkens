    function playGrungeAnthem(playerWon = true) {
      ensureAudio();
      const now = audioCtx.currentTime;
      const roots = playerWon ? [164.81, 146.83, 196, 220, 196, 246.94] : [146.83, 130.81, 123.47, 110, 123.47, 98];
      roots.forEach((root, i) => {
        const start = now + i * 0.32;
        playPowerChord(root, start, 0.34);
        if (i % 2 === 0) {
          playKick(start);
        } else {
