      dramaFreeze: 0,
      lastTime: performance.now()
    };

    let audioCtx = null;
    let masterGain = null;
    let musicTimer = null;
    let guitarNoiseBuffer = null;

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function ensureAudio() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        masterGain = audioCtx.createGain();
        masterGain.gain.value = 0.8;
        masterGain.connect(audioCtx.destination);
        guitarNoiseBuffer = audioCtx.createBuffer(1, audioCtx.sampleRate * 2, audioCtx.sampleRate);
        const data = guitarNoiseBuffer.getChannelData(0);
        for (let i = 0; i < data.length; i++) {
          data[i] = Math.random() * 2 - 1;
        }
      }
      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }
    }

    function makeDistortionCurve(amount = 50) {
      const n = 256;
      const curve = new Float32Array(n);
      for (let i = 0; i < n; i++) {
        const x = (i * 2) / n - 1;
        curve[i] = ((3 + amount) * x * 20 * (Math.PI / 180)) / (Math.PI + amount * Math.abs(x));
      }
      return curve;
    }

    function tone(freq, start, duration, type = "square", volume = 0.06) {
      if (!audioCtx) return;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = type;
      osc.frequency.setValueAtTime(freq, start);
      gain.gain.setValueAtTime(0.0001, start);
      gain.gain.exponentialRampToValueAtTime(volume, start + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.0001, start + duration);
      osc.connect(gain).connect(masterGain || audioCtx.destination);
      osc.start(start);
      osc.stop(start + duration + 0.02);
    }

    function noiseBurst(start, duration = 0.08, volume = 0.08) {
      if (!audioCtx) return;
      const buffer = audioCtx.createBuffer(1, audioCtx.sampleRate * duration, audioCtx.sampleRate);
      const channel = buffer.getChannelData(0);
      for (let i = 0; i < channel.length; i++) {
        channel[i] = (Math.random() * 2 - 1) * (1 - i / channel.length);
      }
      const source = audioCtx.createBufferSource();
      const filter = audioCtx.createBiquadFilter();
      filter.type = "bandpass";
      filter.frequency.value = rand(200, 800);
      const gain = audioCtx.createGain();
      gain.gain.value = volume;
      source.buffer = buffer;
      source.connect(filter).connect(gain).connect(masterGain || audioCtx.destination);
      source.start(start);
    }

    function playPluckedGuitar(freq, start, duration = 0.45, volume = 0.12, options = {}) {
      ensureAudio();
      const source = audioCtx.createBufferSource();
      source.buffer = guitarNoiseBuffer;

      const bandpass = audioCtx.createBiquadFilter();
      bandpass.type = "bandpass";
      bandpass.frequency.setValueAtTime(Math.max(180, freq * 2.2), start);
      bandpass.Q.value = 0.9;

      const lowpass = audioCtx.createBiquadFilter();
      lowpass.type = "lowpass";
      lowpass.frequency.setValueAtTime(Math.max(900, freq * 6), start);
      lowpass.Q.value = 0.6;

      const shaper = audioCtx.createWaveShaper();
      shaper.curve = makeDistortionCurve(options.distortion || 90);
      shaper.oversample = "4x";

      const gain = audioCtx.createGain();
      gain.gain.setValueAtTime(0.0001, start);
      gain.gain.linearRampToValueAtTime(volume, start + 0.006);
      gain.gain.exponentialRampToValueAtTime(volume * 0.42, start + 0.08);
      gain.gain.exponentialRampToValueAtTime(0.0001, start + duration);

      const playbackRate = freq / 110;
      source.playbackRate.setValueAtTime(playbackRate, start);
      if (options.slideTo) {
        source.playbackRate.exponentialRampToValueAtTime(options.slideTo / 110, start + Math.min(0.14, duration * 0.35));
      }

      source.connect(bandpass).connect(lowpass).connect(shaper).connect(gain).connect(masterGain || audioCtx.destination);
      source.start(start, Math.random() * 0.15);
      source.stop(start + duration + 0.03);
      noiseBurst(start, 0.02, 0.03);
    }

    function playGuitarChord(freqs, start, duration = 0.42, volume = 0.11) {
      freqs.forEach((freq, i) => {
        playPluckedGuitar(freq, start + i * 0.008, duration, volume, { distortion: 110 });
      });
    }

    function playHairMetalSqueal(kind = "victory") {
      ensureAudio();
      const now = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      const sub = audioCtx.createOscillator();
      const filter = audioCtx.createBiquadFilter();
      const gain = audioCtx.createGain();
      const subGain = audioCtx.createGain();
      const shaper = audioCtx.createWaveShaper();

      const curve = new Float32Array(256);
      for (let i = 0; i < curve.length; i++) {
        const x = (i / (curve.length - 1)) * 2 - 1;
        curve[i] = Math.tanh(x * 8);
      }

      shaper.curve = curve;
      shaper.oversample = "4x";
      filter.type = "bandpass";
      filter.Q.value = 5;
      filter.frequency.setValueAtTime(kind === "victory" ? 1800 : 1100, now);
      filter.frequency.exponentialRampToValueAtTime(kind === "victory" ? 900 : 500, now + 0.55);

      osc.type = "sawtooth";
      sub.type = "triangle";
      if (kind === "victory") {
        osc.frequency.setValueAtTime(620, now);
        osc.frequency.exponentialRampToValueAtTime(1320, now + 0.12);
        osc.frequency.exponentialRampToValueAtTime(740, now + 0.56);
        sub.frequency.setValueAtTime(155, now);
        sub.frequency.exponentialRampToValueAtTime(185, now + 0.56);
      } else {
        osc.frequency.setValueAtTime(440, now);
        osc.frequency.exponentialRampToValueAtTime(220, now + 0.14);
        osc.frequency.exponentialRampToValueAtTime(130, now + 0.58);
        sub.frequency.setValueAtTime(110, now);
        sub.frequency.exponentialRampToValueAtTime(82, now + 0.58);
      }

      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(0.18, now + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.08, now + 0.18);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.6);

      subGain.gain.setValueAtTime(0.04, now);
      subGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.58);

      osc.connect(shaper).connect(filter).connect(gain).connect(masterGain || audioCtx.destination);
      sub.connect(subGain).connect(masterGain || audioCtx.destination);
      osc.start(now);
      sub.start(now);
      osc.stop(now + 0.62);
      sub.stop(now + 0.62);

      noiseBurst(now + 0.01, 0.06, 0.04);
      noiseBurst(now + 0.12, 0.04, 0.025);
      if (kind === "victory") {
        playPluckedGuitar(329.63, now + 0.02, 0.28, 0.12, { slideTo: 659.25, distortion: 120 });
      } else {
        playPluckedGuitar(196, now + 0.03, 0.3, 0.11, { slideTo: 123.47, distortion: 120 });
      }
    }

    function playBounce() {
