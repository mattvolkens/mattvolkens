<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HIRE ME OR FACE THE PEDAL</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

    :root {
      --bg: #05080a;
      --panel: rgba(5, 12, 8, 0.84);
      --green: #74ff68;
      --pink: #ff4fae;
      --cyan: #54f7ff;
      --amber: #ffca4d;
      --red: #ff3f50;
      --shadow: rgba(116, 255, 104, 0.28);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top, rgba(255, 79, 174, 0.16), transparent 28%),
        radial-gradient(circle at bottom, rgba(84, 247, 255, 0.12), transparent 35%),
        linear-gradient(180deg, #090f11 0%, #040506 100%);
      color: var(--green);
      font-family: "Press Start 2P", monospace;
      overflow: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(
          rgba(255, 255, 255, 0.05) 50%,
          rgba(0, 0, 0, 0.12) 50%
        );
      background-size: 100% 4px;
      opacity: 0.3;
      pointer-events: none;
      mix-blend-mode: screen;
      z-index: 20;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(255, 0, 102, 0.06), transparent 20%, transparent 80%, rgba(84, 247, 255, 0.08)),
        radial-gradient(circle at center, transparent 45%, rgba(0, 0, 0, 0.35) 100%);
      pointer-events: none;
      z-index: 21;
    }

    .app {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.8fr);
      gap: 18px;
      width: min(1400px, calc(100vw - 24px));
      height: min(92vh, 900px);
      margin: 16px auto;
      padding: 16px;
      border: 4px solid rgba(116, 255, 104, 0.45);
      background: rgba(2, 8, 7, 0.58);
      box-shadow: 0 0 28px rgba(116, 255, 104, 0.18), inset 0 0 24px rgba(84, 247, 255, 0.08);
      backdrop-filter: blur(5px);
    }

    .app.prestart {
      opacity: 0;
      pointer-events: none;
    }

    .left-panel {
      position: relative;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .title {
      margin: 0 0 14px;
      font-size: clamp(22px, 2.6vw, 36px);
      line-height: 1.3;
      color: var(--pink);
      text-align: center;
      text-shadow:
        0 0 4px rgba(255, 79, 174, 0.8),
        0 0 12px rgba(255, 79, 174, 0.4),
        0 6px 0 rgba(60, 0, 22, 0.8);
      letter-spacing: 1px;
      transform: skew(-2deg);
    }

    .title .drip {
      display: inline-block;
      position: relative;
    }

    .title .drip::after,
    .title .drip::before {
      content: "";
      position: absolute;
      bottom: -11px;
      width: 8px;
      border-radius: 0 0 10px 10px;
      background: linear-gradient(180deg, var(--pink), #851242);
    }

    .title .drip::before {
      left: 10%;
      height: 14px;
    }

    .title .drip::after {
      right: 14%;
      height: 20px;
    }

    .hud {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
      font-size: clamp(12px, 1.25vw, 16px);
      line-height: 1.6;
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(84, 247, 255, 0.4);
      align-items: center;
    }

    .arena-wrap {
      position: relative;
      flex: 1;
      min-height: 0;
      border: 4px solid rgba(84, 247, 255, 0.35);
      background:
        linear-gradient(180deg, rgba(84, 247, 255, 0.05), transparent 20%),
        radial-gradient(circle at center, rgba(116, 255, 104, 0.08), transparent 60%),
        #020705;
      overflow: hidden;
    }

    #gameCanvas {
      display: block;
      width: 100%;
      height: 100%;
      image-rendering: pixelated;
      cursor: none;
    }

    .flash {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transition: opacity 160ms ease;
      mix-blend-mode: screen;
    }

    .flash.active {
      opacity: 0.92;
    }

    .overlay-text,
    .splash,
    .final-screen,
    .resume-flyover,
    .panther-pop {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 24px;
      pointer-events: none;
    }

    .overlay-text {
      opacity: 0;
      transform: scale(0.88);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .overlay-text.active {
      opacity: 1;
      transform: scale(1);
    }

    .overlay-card,
    .splash-card,
    .final-card {
      max-width: 90%;
      padding: 24px 22px;
      border: 4px solid currentColor;
      background: rgba(6, 8, 14, 0.84);
      box-shadow: 0 0 24px currentColor;
      line-height: 1.9;
    }

    .overlay-card {
      color: var(--amber);
      font-size: clamp(16px, 2vw, 24px);
    }

    .overlay-card.toasty {
      color: var(--red);
      animation: slam 260ms steps(2) 1;
    }

    .splash {
      position: fixed;
      inset: 0;
      pointer-events: auto;
      padding: 28px;
      background:
        radial-gradient(circle at top, rgba(255, 92, 22, 0.28), transparent 30%),
        radial-gradient(circle at bottom, rgba(84, 247, 255, 0.16), transparent 35%),
        rgba(2, 4, 4, 0.96);
      z-index: 30;
    }

    .splash.hidden,
    .final-screen.hidden,
    .resume-flyover.hidden,
    .panther-pop.hidden {
      display: none;
    }

    .splash-card,
    .final-card {
      color: var(--green);
      line-height: 1.8;
      animation: pulse 1s steps(2) infinite;
      font-size: clamp(12px, 1.4vw, 18px);
    }

    .splash-card {
      max-width: min(760px, 92vw);
      padding: 28px 30px;
    }

    .splash-card .coin {
      color: var(--pink);
      display: block;
      margin-bottom: 12px;
      font-size: clamp(20px, 2.2vw, 30px);
    }

    .splash-card .subhead {
      color: var(--amber);
      display: block;
      margin-bottom: 12px;
      font-size: clamp(12px, 1.35vw, 16px);
      line-height: 1.7;
    }

    .splash-card .start-prompt {
      color: var(--cyan);
      margin-top: 18px;
      font-size: clamp(14px, 1.6vw, 20px);
    }

    .splash-card .instruction-line {
      margin: 10px 0;
    }

    .resume-stage {
      position: relative;
      padding-right: 152px;
    }

    .matt-sticker {
      position: absolute;
      top: 12px;
      right: 10px;
      width: 126px;
      height: 168px;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      z-index: 2;
      animation: mattDance 1.2s ease-in-out infinite;
    }

    .matt-burst {
      position: absolute;
      inset: 12px 0 18px;
      background:
        radial-gradient(circle, rgba(255, 202, 77, 0.98) 0 32%, transparent 33%),
        conic-gradient(from 0deg, #ff5a14 0 10%, transparent 10% 20%, #ffca4d 20% 30%, transparent 30% 40%, #ff4fae 40% 50%, transparent 50% 60%, #54f7ff 60% 70%, transparent 70% 80%, #74ff68 80% 90%, transparent 90% 100%);
      clip-path: polygon(50% 0%, 59% 19%, 79% 6%, 72% 28%, 97% 25%, 79% 42%, 100% 50%, 79% 58%, 97% 75%, 72% 72%, 79% 94%, 59% 81%, 50% 100%, 41% 81%, 21% 94%, 28% 72%, 3% 75%, 21% 58%, 0% 50%, 21% 42%, 3% 25%, 28% 28%, 21% 6%, 41% 19%);
      filter: drop-shadow(0 0 12px rgba(255, 90, 20, 0.7));
      transform: rotate(-9deg);
    }

    .matt-photo {
      position: relative;
      width: 92px;
      height: 120px;
      border-radius: 18px;
      border: 4px solid #fff36d;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.25), transparent 28%),
        rgba(0, 0, 0, 0.32);
      overflow: hidden;
      box-shadow: 0 0 22px rgba(255, 202, 77, 0.38);
      transform: rotate(6deg);
    }

    .matt-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      filter: saturate(1.1) contrast(1.05);
    }

    .matt-tag {
      position: absolute;
      bottom: -8px;
      left: 50%;
      transform: translateX(-50%) rotate(-3deg);
      padding: 4px 6px;
      background: #ff4fae;
      color: #14050d;
      font-size: 9px;
      line-height: 1.2;
      border: 2px solid #ffd5ef;
      box-shadow: 0 0 10px rgba(255, 79, 174, 0.42);
    }

    .final-card.win {
      color: var(--amber);
      box-shadow: 0 0 28px var(--amber);
    }

    .final-card.lose {
      color: var(--red);
      box-shadow: 0 0 28px var(--red);
    }

    .resume-flyover {
      z-index: 8;
      background: rgba(2, 5, 5, 0.28);
      overflow-y: auto;
      overflow-x: hidden;
      pointer-events: auto;
      align-items: flex-start;
      justify-content: center;
      padding: 20px;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }

    .resume-flyover-card {
      width: min(980px, 96%);
      max-height: none;
      margin-top: 14px;
      margin-bottom: 24px;
      padding: 20px 22px;
      overflow: visible;
      border: 4px solid var(--amber);
      background: rgba(10, 10, 18, 0.94);
      color: var(--green);
      box-shadow: 0 0 28px rgba(255, 202, 77, 0.58);
      transform: translateX(-160%) rotate(-14deg) scale(0.82);
      opacity: 0;
      touch-action: auto;
    }

    .resume-flyover.active .resume-flyover-card {
      animation: resumeFlyover 2.6s cubic-bezier(0.16, 0.95, 0.3, 1) forwards;
    }

    .resume-flyover-card h2 {
      margin: 0 0 14px;
      color: var(--amber);
      font-size: 16px;
      line-height: 1.5;
    }

    .resume-flyover-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      text-align: left;
    }

    .resume-flyover-item {
      padding: 12px;
      border: 2px dashed rgba(116, 255, 104, 0.35);
      background: rgba(0, 0, 0, 0.22);
    }

    .resume-flyover-card p {
      margin: 0;
      font-size: 10px;
      line-height: 1.8;
    }

    .panther-pop {
      z-index: 9;
      pointer-events: none;
    }

    .panther-pop-card {
      padding: 18px 24px;
      border: 4px solid var(--pink);
      background: rgba(8, 8, 14, 0.92);
      color: var(--amber);
      box-shadow: 0 0 26px rgba(255, 79, 174, 0.45);
      text-align: center;
      opacity: 0;
      transform: scale(0.6) rotate(-10deg);
    }

    .panther-pop.active .panther-pop-card {
      animation: pantherSlam 900ms cubic-bezier(0.18, 0.9, 0.3, 1) forwards;
    }

    .panther-face {
      font-size: clamp(52px, 8vw, 110px);
      line-height: 1;
      display: block;
      filter: drop-shadow(0 0 14px rgba(255, 202, 77, 0.38));
    }

    .panther-label {
      display: block;
      margin-top: 10px;
      font-size: clamp(14px, 2vw, 24px);
      color: var(--pink);
    }

    .resume-panel {
      position: relative;
      padding: 16px;
      border: 4px solid rgba(255, 79, 174, 0.4);
      background: var(--panel);
      box-shadow: inset 0 0 20px rgba(255, 79, 174, 0.06);
      overflow: hidden;
    }

    .resume-panel::before {
      content: "RESUME REVEALER 9000";
      display: block;
      margin-bottom: 14px;
      color: var(--pink);
      font-size: 14px;
      text-shadow: 0 0 8px rgba(255, 79, 174, 0.45);
    }

    .resume-status {
      margin-bottom: 14px;
      color: var(--amber);
      font-size: 12px;
      line-height: 1.8;
    }

    .resume-items {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: calc(100% - 64px);
      overflow: auto;
      padding-right: 4px;
    }

    .resume-item {
      opacity: 0.2;
      padding: 14px;
      border: 3px dashed rgba(116, 255, 104, 0.18);
      background: rgba(0, 0, 0, 0.18);
      transform: translateY(8px);
      transition:
        opacity 400ms ease,
        transform 400ms ease,
        border-color 400ms ease,
        box-shadow 400ms ease;
      line-height: 1.7;
      font-size: 11px;
    }

    .resume-item.visible {
      opacity: 1;
      transform: translateY(0);
      border-color: rgba(116, 255, 104, 0.5);
      box-shadow: 0 0 18px rgba(116, 255, 104, 0.12);
    }

    .resume-item h3 {
      margin: 0 0 10px;
      font-size: 13px;
      color: var(--cyan);
    }

    .resume-item p {
      margin: 0;
    }

    .resume-item strong {
      color: var(--amber);
    }

    .legend {
      margin-top: 12px;
      font-size: 10px;
      color: rgba(116, 255, 104, 0.8);
      line-height: 1.8;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.58; }
    }

    @keyframes slam {
      0% { transform: scale(1.6) rotate(-7deg); }
      100% { transform: scale(1) rotate(0); }
    }

    @keyframes mattDance {
      0%, 100% { transform: translateY(0) rotate(-3deg) scale(1); }
      25% { transform: translateY(-4px) rotate(3deg) scale(1.03); }
      50% { transform: translateY(2px) rotate(-5deg) scale(0.99); }
      75% { transform: translateY(-6px) rotate(5deg) scale(1.02); }
    }

    @keyframes resumeFlyover {
      0% { transform: translateX(-165%) rotate(-18deg) scale(0.82); opacity: 0; }
      22% { transform: translateX(8%) rotate(4deg) scale(1.02); opacity: 1; }
      65% { transform: translateX(0) rotate(-2deg) scale(1); opacity: 1; }
      100% { transform: translateX(0) rotate(0deg) scale(1); opacity: 1; }
    }

    @keyframes pantherSlam {
      0% { opacity: 0; transform: scale(0.5) rotate(-12deg); }
      30% { opacity: 1; transform: scale(1.12) rotate(3deg); }
      70% { opacity: 1; transform: scale(0.98) rotate(-2deg); }
      100% { opacity: 0; transform: scale(1.04) rotate(0deg); }
    }

    @media (max-width: 960px) {
      .app {
        grid-template-columns: 1fr;
        width: calc(100vw - 16px);
        height: auto;
        min-height: calc(100vh - 16px);
        margin: 8px auto;
        padding: 10px;
      }

      .arena-wrap {
        min-height: 50vh;
      }

      .resume-panel {
        min-height: 32vh;
      }

      .resume-flyover {
        padding: 10px;
      }

      .resume-flyover-card {
        width: 100%;
        margin-top: 8px;
        margin-bottom: 18px;
        padding: 14px;
      }

      .resume-flyover-grid {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .resume-stage {
        padding-right: 0;
        padding-top: 154px;
      }

      .matt-sticker {
        top: 12px;
        left: 50%;
        right: auto;
        transform: translateX(-50%);
      }
    }
  </style>
</head>
<body>
  <div class="splash" id="splashScreen">
    <div class="splash-card">
      <div class="coin">HIRE ME OR FACE THE PEDAL</div>
      <div class="subhead">MATT VOLKENS' JHS APPLICATION GAME</div>
      <div class="instruction-line">MOVE WITH YOUR MOUSE OR THE ARROW KEYS.</div>
      <div class="instruction-line">GET THE PEDAL PAST JOSH TO UNLOCK THE RESUME.</div>
      <div class="instruction-line">FIRST TO 6 PLAYER POINTS REVEALS EVERYTHING.</div>
      <div class="instruction-line">IF JOSH HITS 3 FIRST, THE FLOATING HEAD MOCKS YOU.</div>
      <div class="start-prompt">CLICK OR PRESS ENTER TO START</div>
    </div>
  </div>

  <div class="app prestart" id="appRoot">
    <section class="left-panel">
      <h1 class="title"><span class="drip">HIRE ME OR FACE THE PEDAL</span></h1>
      <div class="hud">
        <div id="scoreboard">PLAYER 0 : 0 JOSH</div>
        <div>ARROWS OR MOUSE // CRUSH THE FLOATING HEAD</div>
      </div>
      <div class="arena-wrap">
        <canvas id="gameCanvas" width="960" height="540" aria-label="Hire Me Or Face The Pedal game"></canvas>
        <div class="flash" id="flashLayer"></div>
        <div class="overlay-text" id="overlayText">
          <div class="overlay-card" id="overlayCard">RESUME UNLOCKED</div>
        </div>
        <div class="final-screen hidden" id="finalScreen">
          <div class="final-card" id="finalCard"></div>
        </div>
        <div class="resume-flyover hidden" id="resumeFlyover">
          <div class="resume-flyover-card" id="resumeFlyoverCard"></div>
        </div>
        <div class="panther-pop hidden" id="pantherPop">
          <div class="panther-pop-card">
            <span class="panther-face">🐈‍⬛</span>
            <span class="panther-label">PANTHER SCREAM</span>
          </div>
        </div>
      </div>
    </section>

    <aside class="resume-panel">
      <div class="resume-stage">
        <div class="matt-sticker" aria-hidden="true">
          <div class="matt-burst"></div>
          <div class="matt-photo">
            <img id="mattStickerImage" alt="Matt Volkens dancing sticker" />
          </div>
          <div class="matt-tag">MATT MODE</div>
        </div>
        <div class="resume-status" id="resumeStatus">RESUME LOCKED. SCORE TO EXTRACT PROFESSIONAL CREDENTIALS.</div>
        <div class="resume-items" id="resumeItems"></div>
      </div>
      <div class="legend">
        POINTS = QUALIFICATIONS.<br />
        LOSING TO THE HEAD MAY REDUCE MORALE.<br />
        THE CENTAUR HAS NO HR AUTHORITY.
      </div>
    </aside>
  </div>

  <script>
    const canvas = document.getElementById("gameCanvas");
    const ctx = canvas.getContext("2d");
    const appRoot = document.getElementById("appRoot");
    const scoreboard = document.getElementById("scoreboard");
    const splashScreen = document.getElementById("splashScreen");
    const finalScreen = document.getElementById("finalScreen");
    const finalCard = document.getElementById("finalCard");
    const resumeFlyover = document.getElementById("resumeFlyover");
    const resumeFlyoverCard = document.getElementById("resumeFlyoverCard");
    const pantherPop = document.getElementById("pantherPop");
    const resumeItems = document.getElementById("resumeItems");
    const resumeStatus = document.getElementById("resumeStatus");
    const overlayText = document.getElementById("overlayText");
    const overlayCard = document.getElementById("overlayCard");
    const flashLayer = document.getElementById("flashLayer");
    const mattStickerImage = document.getElementById("mattStickerImage");

    const W = canvas.width;
    const H = canvas.height;
    const CENTER_X = W / 2;
    const CENTER_Y = H / 2;
    const JOSH_IMAGE_SRC = "data:image/webp;base64,";
    const MATT_IMAGE_SRC = "data:image/jpeg;base64,";
    const joshPhoto = new Image();
    joshPhoto.src = JOSH_IMAGE_SRC;
    mattStickerImage.src = MATT_IMAGE_SRC;
    const BG_MUSIC_SRC = "data:audio/mpeg;base64,";
    const PANTHER_SOUND_SRC = "data:audio/mpeg;base64,";
    const POINT_SOUND_SRC = "data:audio/mpeg;base64,";
    const bgMusic = new Audio(BG_MUSIC_SRC);
    bgMusic.loop = true;
    bgMusic.preload = "auto";
    bgMusic.volume = 0.35;
    const pantherClip = new Audio(PANTHER_SOUND_SRC);
    pantherClip.preload = "auto";
    pantherClip.volume = 0.8;
    const pointClip = new Audio(POINT_SOUND_SRC);
    pointClip.preload = "auto";
    pointClip.volume = 0.9;

    const resumeData = [
      {
        title: "Point 1 // Name + Title",
        body: "MATT VOLKENS \u2014 Senior Communications Specialist // Storytelling // Content Strategy // Editorial Operations"
      },
      {
        title: "Point 2 // Summary",
        body: "Communications and content strategist with 10 years drafting and editing across corporate, consumer, and employee channels, managing editorial calendars and production pipelines, building reporting frameworks, and coordinating cross-functionally to keep stories consistent and accurate at scale. Parent of two young boys with a genuine personal connection to Life360's mission."
      },
      {
        title: "Point 3 // Journey Church",
        body: "Worship Director // Senior Communications and Content Lead (2020\u2013Present): Founded and grew Journey Worship to nearly 1,000,000 streams across Spotify, YouTube, and major platforms using organic-first storytelling, staggered releases, event-driven content, and community engagement strategy. Drafted and edited integrated content across email, social, digital, and in-person channels while keeping brand voice consistent across every touchpoint."
      },
      {
        title: "Point 4 // Communications Director",
        body: "Journey Church (2015\u20132020): Owned all organizational communications as the primary brand steward and writer across email campaigns, social media, website content, event communications, newsletters, internal announcements, and external-facing messaging. Ran a weekly production pipeline across email, social, digital, and print while managing Mailchimp, WordPress, vendors, and cross-functional coordination."
      },
      {
        title: "Point 5 // Core Competencies + Tools",
        body: "Corporate and employee communications, content drafting and editing, executive briefing materials, editorial calendar management, communications reporting, coverage analysis, brand voice, messaging consistency, email marketing, social strategy, newsletters, blogs, campaign project management, and AI-first workflows. Daily tools: Claude, ChatGPT, Perplexity, Zapier, Granola, Wispr Flow, Mailchimp, WordPress, Canva, Adobe Creative Suite, Google Workspace, Microsoft Office, Asana, Basecamp, Slack, and Webflow."
      },
      {
        title: "Point 6 // Education + Sign-off",
        body: "Palm Beach Atlantic University \u2014 B.S. Exercise Science (2012\u20132015). Also: Leadership and Events Apprentice, coordinating weekly programming for 100+ participants. Thanks for playing. Now hire me."
      }
    ];

    resumeData.forEach((item) => {
      const card = document.createElement("article");
      card.className = "resume-item";
      card.innerHTML = `<h3>${item.title}</h3><p>${item.body}</p>`;
      resumeItems.appendChild(card);
    });

    const game = {
      started: false,
      over: false,
      playerScore: 0,
      joshScore: 0,
      up: false,
      down: false,
      mouseY: H / 2,
      player: {
        x: 28,
        y: H / 2 - 50,
        width: 16,
        height: 100,
        speed: 420
      },
      josh: {
        x: W - 118,
        y: H / 2,
        width: 98,
        height: 120,
        speed: 235,
        wobble: 0,
        flash: 0,
        drift: 0,
        reactionLag: 0
      },
      ball: {
        x: CENTER_X,
        y: CENTER_Y,
        size: 20,
